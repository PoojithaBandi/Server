---
- name: Auto deletion of server after 30 days
  hosts: localhost
  gather_facts: false
  connection: local
  
  colections: amazon.aws
  
  vars:
    today: "{{ansible_date_time.date}}"
  tasks:
  - name: Get expired ec2 instance
    amazon.aws.ec2_instance_info:
      region: "{{aws_region}}"
      filters:
        "tag. ExpiryDate": "{{ today }}"
        instance-state-name: running
    register: expired

  - name: Display expired instance

    debug:
      msg: "{{item_instance_id}}"
    loop: "{{expired.instances}}"
    when: expired.instances length>0
  - name: delete expire ec2 instance
    amazon.aws.ec2_instance:
      region: "{{aws_region}}"

      instance_ids: "{{item.instance_id}}"

      state: absent

      wait: true

    loop: "{{expired.instances}}"

    when: expired.instance|length>0
